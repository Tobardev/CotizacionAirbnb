<?xml version="1.0" encoding="UTF-8"?>
<project name="CotizacionAirbnbNetBeansAnt-impl" default="default" basedir="..">
    <property file="nbproject/project.properties"/>
    <property environment="env"/>

    <target name="-init">
        <mkdir dir="${build.dir}"/>
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="compile" depends="-init">
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}" includeantruntime="false" encoding="${source.encoding}" source="${javac.source}" target="${javac.target}">
            <classpath>
                <pathelement path="${javac.classpath}"/>
            </classpath>
        </javac>
        <copy todir="${build.classes.dir}">
            <fileset dir="${src.dir}" excludes="**/*.java,**/*.form"/>
        </copy>
    </target>

    <target name="jar" depends="compile">
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}" manifest="${manifest.file}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>

    <target name="run" depends="jar">
        <java jar="${dist.jar}" fork="true">
            <jvmarg line="${run.jvmargs}"/>
        </java>
    </target>

    <target name="default" depends="jar"/>
</project>
